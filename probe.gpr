-- probe.gpr — GGUF inspection tool
--
-- Build: gprbuild -P probe.gpr -XSDKROOT=$(xcrun --show-sdk-path)
-- Run:   ./obj/gguf_probe <model.gguf>

with "shared.gpr";

project Probe is

   for Source_Dirs use ("tools/probes", "src/llm");
   for Object_Dir use "obj";
   for Exec_Dir use "obj";
   for Main use ("gguf_probe.adb", "gemma_probe.adb", "gemma_tok.adb",
                 "llama_probe.adb", "sampler_probe.adb", "q4k_probe.adb",
                 "quant_probe.adb", "meta_dump.adb", "model_scan.adb",
                 "chat_probe.adb", "requantize.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnatwn", "-gnatX", "-g");
   end Compiler;

   package Linker is
      for Default_Switches ("Ada") use Shared.Linker_Switches;
   end Linker;

   package Binder is
      for Default_Switches ("Ada") use ("-E");
   end Binder;

end Probe;
