-- tests/llm_tests.gpr — LLM Unit Tests
--
-- Self-contained: pulls the engine sources directly from ../src and ../src/llm
-- (there is no separate llm.gpr — the only chat path is the encrypted server).
--
-- Build: gprbuild -P tests/llm_tests.gpr -XSDKROOT=$(xcrun --show-sdk-path)

with "../shared.gpr";

project LLM_Tests is

   for Source_Dirs use (".", "../src", "../src/llm");
   for Object_Dir use "../obj/tests";
   for Exec_Dir use "../obj";
   for Main use ("test_rmsnorm.adb", "test_moe.adb",
                 "test_tokenizer.adb", "test_tensor.adb",
                 "test_deltanet.adb", "test_deltanet_blk.adb", "test_fullattn.adb", "test_block.adb",
                 "test_tokenizer_real.adb", "test_weights_real.adb", "test_qmatvec_real.adb",
                 "test_gemma.adb",
                 "test_qmatvec_q4k.adb", "test_qmatvec_guard.adb",
                 "test_quant.adb", "test_kquant_synth.adb",
                 "test_q3k_real.adb", "test_q2k_real.adb",
                 "test_ctx_window.adb",
                 "test_rope_scale.adb", "test_kv_pool.adb",
                 "test_sampler.adb",
                 "test_pool.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnatwn", "-gnatX", "-O3", "-march=native");
   end Compiler;

   package Linker is
      for Default_Switches ("Ada") use Shared.Linker_Switches;
   end Linker;

   package Binder is
      for Default_Switches ("Ada") use ("-E");
   end Binder;

end LLM_Tests;
