-- tests/llm_tests.gpr — LLM Unit Tests
--
-- Build: gprbuild -P tests/llm_tests.gpr -XSDKROOT=$(xcrun --show-sdk-path) -largs -XSDKROOT=$(xcrun --show-sdk-path)

with "../llm.gpr";

project LLM_Tests is

   for Source_Dirs use (".");
   for Object_Dir use "../obj/tests";
   for Exec_Dir use "../obj";
   for Main use ("test_rmsnorm.adb");

   package Compiler is
      for Default_Switches ("Ada") use LLM.Compiler'Default_Switches ("Ada");
   end Compiler;

   package Linker is
      for Default_Switches ("Ada") use LLM.Linker'Default_Switches ("Ada");
   end Linker;

   package Binder is
      for Default_Switches ("Ada") use LLM.Binder'Default_Switches ("Ada");
   end Binder;

end LLM_Tests;
