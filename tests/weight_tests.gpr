-- tests/weight_tests.gpr — H19 weight-streaming integration test.
--
-- Builds the Remote_AEAD_Source + the weight-store responder (in ../src/server)
-- together with the engine byte-source (../src/llm) and the secure channel
-- (via session.gpr -> crypto.gpr), plus an in-memory loopback test that asserts
-- a remote-sourced GGUF read is byte-identical to a local-file read.
--
-- This is the one project that spans src/llm AND Secure_Channel: server.gpr
-- already does so for production, and this project mirrors its source set
-- (src/llm + src/secure + src/server) plus the test directory.
--
-- Build: MACOSX_DEPLOYMENT_TARGET=14.0 \
--        gprbuild -P tests/weight_tests.gpr -XSDKROOT=$(xcrun --show-sdk-path)

with "../shared.gpr";
with "../session.gpr";

project Weight_Tests is

   for Source_Dirs use (".", "../src/llm", "../src/secure", "../src/server");
   for Object_Dir use "../obj/weight_tests";
   for Exec_Dir use "../obj";
   for Main use ("test_weight_stream.adb", "test_weight_cache.adb",
                 "test_weight_disk.adb", "test_weight_pin.adb",
                 "test_weight_prefetch.adb", "test_weight_parity.adb",
                 "test_weight_egress.adb", "test_weight_partial.adb",
                 "test_weight_concurrent.adb");

   package Compiler is
      for Default_Switches ("Ada") use Shared.Ada_O3;
   end Compiler;

   package Linker is
      for Default_Switches ("Ada") use Shared.Linker_Switches;
   end Linker;

   package Binder is
      for Default_Switches ("Ada") use ("-E");
   end Binder;

end Weight_Tests;