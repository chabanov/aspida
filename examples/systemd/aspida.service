[Unit]
Description=Aspida LLM Inference Server
Documentation=https://github.com/chabanov/aspida
After=network.target

[Service]
Type=simple
User=aspida
Group=aspida
WorkingDirectory=/opt/aspida

# Environment
Environment="ASPIDA_BIND=127.0.0.1"
Environment="ASPIDA_CLIENT_TOKEN=%q"
EnvironmentFile=/etc/aspida/aspida.env

# Executable
ExecStart=/opt/aspida/bin/secure_server 8080
ExecReload=/bin/kill -HUP $MAINPID

# Restart policy
Restart=on-failure
RestartSec=5s

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/aspida/sessions
ReadOnlyPaths=/opt/aspida/models

# Resource limits
LimitNOFILE=65536
LimitNPROC=512

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=aspida

[Install]
WantedBy=multi-user.target
