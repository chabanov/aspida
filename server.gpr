-- server.gpr — encrypted chat server + client (engine + crypto + sockets).
--
-- Builds the Qwen engine together with the secure session layer and the
-- two mains. Withs session.gpr (crypto + secure channel); owns the engine
-- sources, the socket transport/protocol, and the server-side integration.
--
-- Build: gprbuild -P server.gpr -XSDKROOT=$(xcrun --show-sdk-path)
-- Run:   QWEN_MODEL_PATH=... ./obj/secure_server [port]
--        ./obj/secure_client <host> <port> <server_pub_hex> <prompt...>

with "session.gpr";

project Server is

   for Source_Dirs use ("src/llm", "src/secure", "src/server");
   for Object_Dir use "obj/server";
   for Exec_Dir use "obj";
   for Main use ("secure_server.adb", "secure_client.adb");

   package Compiler is
      for Default_Switches ("Ada") use
        ("-gnatwa", "-gnatwe", "-gnatX", "-O3", "-march=native");
   end Compiler;

   package Linker is
      for Default_Switches ("Ada") use
        ("-L" & external ("SDKROOT", "") & "/usr/lib",
         "-Wl,-syslibroot," & external ("SDKROOT", ""));
   end Linker;

   package Binder is
      for Default_Switches ("Ada") use ("-E");
   end Binder;

end Server;
