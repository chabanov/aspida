-- genref.gpr — builds gpu/experiments/phase1/gen_ref.adb (Phase-1 GPU reference generator).
-- Only includes gpu/experiments/phase1 (NOT gpu/experiments/phase0, whose main needs the CUDA object).
with "shared.gpr";

project Genref is
   for Source_Dirs use ("gpu/experiments/phase1", "src", "src/llm");
   for Object_Dir use "obj";
   for Exec_Dir use "obj";
   for Main use ("gen_ref.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnatwn", "-gnatX", "-O2", "-march=native");
   end Compiler;

   package Linker is
      for Default_Switches ("Ada") use Shared.Linker_Switches;
   end Linker;

   package Binder is
      for Default_Switches ("Ada") use ("-E");
   end Binder;
end Genref;
