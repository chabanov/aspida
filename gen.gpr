-- gen.gpr — raw text-generation probe on the real model
with "shared.gpr";
project Gen is
   for Source_Dirs use ("tools/probes", "src", "src/llm");
   for Object_Dir use "obj";
   for Exec_Dir use "obj";
   for Main use ("gen_probe.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnatwn", "-gnatX", "-O3", "-march=native");
   end Compiler;

   package Linker is
      for Default_Switches ("Ada") use Shared.Linker_Switches;
   end Linker;

   package Binder is
      for Default_Switches ("Ada") use ("-E");
   end Binder;
end Gen;
