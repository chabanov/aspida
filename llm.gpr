-- llm.gpr — Native LLM Chat
--
-- Build: gprbuild -P llm.gpr -XSDKROOT=$(xcrun --show-sdk-path)
-- Run:   ./obj/llm_main [dim] [layers]

project LLM is

   for Source_Dirs use ("src", "src/llm");
   for Object_Dir use "obj";
   for Exec_Dir use "obj";
   for Main use ("llm_main.adb");

   package Compiler is
      --  -gnatwa: all warnings; -gnatwe: warnings as errors; -gnatX: extensions;
      --  -O3 + -march=native: optimise & auto-vectorise the math (pure Ada).
      for Default_Switches ("Ada") use
        ("-gnatwa", "-gnatwe", "-gnatX", "-O3", "-march=native");
   end Compiler;

   --  Self-contained: no external BLAS/inference libraries are linked.
   package Linker is
      for Default_Switches ("Ada") use
        ("-L" & external ("SDKROOT", "") & "/usr/lib",
         "-Wl,-syslibroot," & external ("SDKROOT", ""));
   end Linker;

   package Binder is
      for Default_Switches ("Ada") use ("-E");
   end Binder;

end LLM;
