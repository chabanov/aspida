-- aspida_cli.gpr — Aspida CLI client generator
--
-- Build: gprbuild -P aspida_cli.gpr -XSDKROOT=$(xcrun --show-sdk-path)

project Aspida_Cli is

   for Source_Dirs use ("src", "src/llm");
   for Object_Dir use "obj";
   for Exec_Dir use "obj";
   for Main use ("main.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnatwa", "-gnatwe");
   end Compiler;

   package Linker is
      for Default_Switches ("Ada") use
        ("-L" & external ("SDKROOT", "") & "/usr/lib",
         "-Wl,-syslibroot," & external ("SDKROOT", ""));
   end Linker;

   package Binder is
      for Default_Switches ("Ada") use ("-E");
   end Binder;

end Aspida_Cli;
